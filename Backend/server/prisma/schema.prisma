// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  schools   School[]
  templates TestTemplate[]
  tests     Test[]
}

model School {
  id      Int     @id @default(autoincrement())
  name    String
  owner   User    @relation(fields: [ownerId], references: [id])
  ownerId Int
  classes Class[]
  // relacja jawnie nazwana – łatwiej uniknąć konfliktów w przyszłości
  tests   Test[]  @relation("SchoolTests")
}

model Class {
  id       Int      @id @default(autoincrement())
  name     String
  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId Int
  students Student[]
  order    Int
  tests    Test[]   @relation("ClassTests")
}

model Student {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  gender    String
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId   Int
  order     Int
  results   TestResult[]
}

model TestTemplate {
  id        Int        @id @default(autoincrement())
  name      String
  owner     User       @relation(fields: [ownerId], references: [id])
  ownerId   Int
  tasks     TestTask[]
  tests     Test[]
}

model TestTask {
  id          Int           @id @default(autoincrement())
  description String
  minPoints   Int
  maxPoints   Int
  order       Int
  template    TestTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId  Int
  results     TestResult[]
}

model Test {
  id          Int           @id @default(autoincrement())
  name        String
  date        DateTime      @default(now())
  owner       User          @relation(fields: [ownerId], references: [id])
  ownerId     Int

  template    TestTemplate  @relation(fields: [templateId], references: [id])
  templateId  Int

  // NOWE: scope (opcjonalne) – możesz przypiąć test do szkoły i/lub klasy
  school      School?       @relation("SchoolTests", fields: [schoolId], references: [id], onDelete: SetNull)
  schoolId    Int?

  class       Class?        @relation("ClassTests",  fields: [classId],  references: [id], onDelete: SetNull)
  classId     Int?

  results     TestResult[]

  // przyspiesza „resume or create”
  @@unique([ownerId, templateId, name])
}

model TestResult {
  id        Int       @id @default(autoincrement())

  test      Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId    Int

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int

  task      TestTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    Int

  points    Float

  @@unique([testId, studentId, taskId])
}
